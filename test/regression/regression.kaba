use os

func test(filename: os.Path) -> bool
	var s = str(filename).head(len(str(filename)) - 4) + ".kaba"
	try
		var r1 = os.shell_execute("kaba '{{s}}'")
		var r2 = os.fs.read(filename)


		for i in s.num:42
			s.add(' ')
		if r1 == r2
			print(s + "ok")
			return true

		print(s + "Fehler")
		print("--------------------------------------------------")
		print("erwartet:")
		print(r2)
		print("--------------------------------------------------")
		print("Ausgabe:")
		print(r1)
		print("--------------------------------------------------")
		return false
	except
		print("failed running")
		return false

func main()
	var list = os.fs.search(".", "*.reg", "fr")
	for e in list
		let x = test(e)
