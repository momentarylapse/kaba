use xhui as hui
#use hui


func xdraw(p: hui.Painter)
	print("draw {{p.width}}")
	p.set_color(Color.RED)
	p.draw_rect([100,200,100,200])


func main()
	var w = new shared hui.Window("test", 800, 600)
	w.from_source("
Dialog win 'bla'
	Grid ? ''
		Button b 'Test' noexpandy
		---|
		Button b2 'Test' noexpandy
		---|
		DrawingArea area '' expandy height=300
")
	w.event("b", func() print("hi"))
	w.event_x("area", "hui:draw", xdraw)
	hui.fly_and_wait(w)
	